NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full OAuth callback URL, OR leave empty and set NEXT_PUBLIC_APP_URL (callback = APP_URL + /api/auth/callback).
# Register each environment’s URI in Google Cloud (e.g. http://localhost:3000/api/auth/callback and https://your-app.vercel.app/api/auth/callback).
GOOGLE_REDIRECT_URI=
# Site origin, no trailing slash. Vercel: https://your-project.vercel.app — used for OAuth callback when GOOGLE_REDIRECT_URI is unset.
NEXT_PUBLIC_APP_URL=
